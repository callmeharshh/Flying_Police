# Required for CLI (agent always on) and optional UI LangChain agent
OPENAI_API_KEY=sk-...

# Optional — leave blank to disable Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional — leave blank to run without Monad anchoring
MONAD_RPC_URL=
MONAD_CHAIN_ID=
MONAD_PRIVATE_KEY=
EVIDENCE_REGISTRY_ADDRESS=
MONAD_EXPLORER_TX_URL=

# Optional — Lighthouse IPFS for full evidence JSON (https://lighthouse.storage/)
LIGHTHOUSE_API_KEY=
